{
  "manifest_version": 3,
  "name": "AI-Translator",
  "description": "AI translation for selected text and full web pages with DeepSeek and OpenAI support.",
  "version": "0.1.4",
  "permissions": [
    "activeTab",
    "contextMenus",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://api.deepseek.com/*",
    "https://api.openai.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "assets/icons/icon-v6-16.png",
      "32": "assets/icons/icon-v6-32.png"
    },
    "default_title": "AI Translate",
    "default_popup": "src/popup/popup.html"
  },
  "icons": {
    "16": "assets/icons/icon-v6-16.png",
    "32": "assets/icons/icon-v6-32.png",
    "48": "assets/icons/icon-v6-48.png",
    "128": "assets/icons/icon-v6-128.png"
  },
  "options_page": "src/options/options.html",
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "src/content/content.js"
      ],
      "css": [
        "src/content/content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
